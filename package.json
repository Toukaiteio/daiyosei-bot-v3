{
  "name": "daiyosei-bot-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js rewrite of Daiyosei Bot with OneBot and OpenAI Agents SDK.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "web:dev": "vite --host 127.0.0.1",
    "web:build": "vite build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@openai/agents": "^0.8.5",
    "@tanstack/react-query": "^5.100.5",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "fastify": "^5.8.5",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.9",
    "openai": "^6.34.0",
    "openmemory-js": "^1.3.3",
    "pino": "^10.3.1",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
