HTTP_HOST=127.0.0.1
HTTP_PORT=3000
LOG_LEVEL=info
WEBUI_AUTO_START=true

BOT_NAME=琪露诺
BOT_PERSONA=
PLUGINS_DIR=plugins
SKILLS_DIR=skills
STORAGE_DB_PATH=data/daiyosei.db

ONEBOT_ENABLED=true
ONEBOT_HOST=127.0.0.1
ONEBOT_PORT=6199
ONEBOT_PATH=/onebot/v11
ONEBOT_RESTRICT_SOURCE_HOSTS=false
ONEBOT_ALLOWED_SOURCE_HOSTS=
ONEBOT_BLOCK_PUBLIC_REQUESTS=true
# 群聊唤醒关键词，逗号分隔；英文不区分大小写。私聊始终响应。
# 留空则使用默认值: 琪露诺,Cirno,天才
ONEBOT_WAKE_KEYWORDS=

MEMES_ENABLED=true
MEMES_ALLOWED_CATEGORIES=
MEMES_DISABLED_MEMES=

SANDBOX_WORKSPACE_ROOT=.
SANDBOX_ALLOW_NETWORK=false
SANDBOX_ALLOW_PERSISTENT_WRITES=false
SANDBOX_MAX_EXECUTION_MS=10000

# OpenMemory 配置（长期记忆系统）
# 官方文档: https://github.com/CaviraOSS/OpenMemory
#
# OpenMemory 支持两种模式：
# 1. 本地模式（默认）: 不需要配置 OPENMEMORY_BASE_URL，使用本地 SQLite 数据库
# 2. 远程模式: 配置 OPENMEMORY_BASE_URL 连接到远程 OpenMemory 服务器
#
# 如果不配置 OPENMEMORY_BASE_URL，系统将使用本地模式，内存存储在 data/openmemory.sqlite
#
OPENMEMORY_BASE_URL=
OPENMEMORY_API_KEY=
OM_TIER=smart
